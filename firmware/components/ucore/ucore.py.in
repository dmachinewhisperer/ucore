import _ucore

INFO = r"""@_UCORE_BOARD_INFO@"""

# ── Pipes ────────────────────────────────────────────────────────────────
#
# Named byte channels from device → host. Designed for streaming sensor
# data (ADC, IMU, temperature, etc.) to a host-side consumer that plots
# or logs it in real time.
#
# Typical pattern: a %%ucore cell starts a background _thread that writes
# samples to a pipe, then returns. The cell completes immediately; the
# thread keeps emitting frames. A second cell on the host reads the pipe
# via `ucore_pipes.open(name)`.
#
#   import ucore, _thread, machine, time, struct
#   adc = machine.ADC(machine.Pin(4))
#   pipe = ucore.open_pipe("adc")
#   def run():
#       while ucore.is_pipe_open("adc"):
#           pipe.write(struct.pack("<f", adc.read_uv() / 1e6))
#           time.sleep_ms(20)
#   _thread.start_new_thread(run, ())
#
# Cap: 65535 bytes per write (uint16 length field on the wire).

_open_pipes = set()


class Pipe:
    def __init__(self, name):
        self.name = name

    def write(self, data):
        _ucore.pipe_write(self.name, data)

    def close(self):
        close_pipe(self.name)

    def __enter__(self):
        return self

    def __exit__(self, *exc):
        self.close()


def open_pipe(name):
    """Open a named pipe and return a Pipe object you can write() to."""
    if name not in _open_pipes:
        _ucore.pipe_open(name)
        _open_pipes.add(name)
    return Pipe(name)


def close_pipe(name):
    """Close a pipe by name. Idempotent. Background threads polling
    is_pipe_open(name) will see False and exit cooperatively."""
    if name in _open_pipes:
        _open_pipes.discard(name)
        try:
            _ucore.pipe_close(name)
        except OSError:
            # transport gone — pipe is effectively closed
            pass


def is_pipe_open(name):
    """True iff `name` is currently open. Background producer loops should
    use this as their stop condition."""
    return name in _open_pipes
